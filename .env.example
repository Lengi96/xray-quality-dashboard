# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xray_dashboard"

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Demo mode — set to "true" to use mock data without Jira/Xray credentials
DEMO_MODE="true"

# Jira (optional — can configure per-project in Settings UI)
JIRA_BASE_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""

# Xray Cloud (optional)
XRAY_CLIENT_ID=""
XRAY_CLIENT_SECRET=""

# Encryption key for stored credentials (use NEXTAUTH_SECRET value)
ENCRYPTION_KEY=""
